# Environment files — developer-local, never committed (see CLAUDE.md
# "Local Environment Files" policy). Broadened beyond plain .env to cover
# common variants (.env.local, .env.*.local, per-environment files) so a
# stray one is never one `git add` away from being committed.
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
backend/.env
backend/.env.local
backend/.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/

# Node / frontend
node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
npm-debug.log*

# Editors / OS / local tool config
.vs/
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db

# Database
*.sqlite3

# Docker
docker/.env

# Logs
*.log
logs/*.log

# PDF build scratch (generated locally when re-rendering Project_SRS.pdf)
*.pdf.tmp

# Accidental full-repo archives at the project root (GC-6: a stray
# university-management-system.zip was previously committed here by
# mistake — this repo is the source of truth, not a zip snapshot of it).
/*.zip
