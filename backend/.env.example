# Backend environment configuration — placeholder values only.
# Copy to .env and fill in real values. Never commit the real .env file.

ENVIRONMENT=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ict_education

# JWT / Auth
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# API
API_V1_PREFIX=/api/v1
ENVIRONMENT=development

# CORS (frontend origin during local development)
FRONTEND_ORIGIN=http://localhost:5173
